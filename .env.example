# Contámelo E2E Tests Configuration

# Ambiente: LOCAL, DEV, STAGING, o PROD
ENVIRONMENT=LOCAL

# Credenciales de usuario de prueba
# Requeridas para login y creación de datos vía API
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=password123

# Para LOCAL: asegúrate de que la app corre en http://localhost:5173
# Para otros ambientes: las URLs se configuran automáticamente en utils/environment.ts
